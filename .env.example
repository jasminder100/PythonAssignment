# -------------------------------------------------------
# S3 File Manager — Environment Variables Template
# -------------------------------------------------------
# HOW TO USE:
#   1. Make a copy of this file and name it exactly:  .env
#   2. Fill in your real values below
#   3. Never share or upload your .env file to GitHub
# -------------------------------------------------------

MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1